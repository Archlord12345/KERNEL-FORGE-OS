#!/bin/bash

# KERNEL-FORGE Control Panel & Automation
# Design: Futurist CLI

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

show_menu() {
    clear
    echo -e "${CYAN}====================================================${NC}"
    echo -e "${CYAN}          KERNEL-FORGE OS - CONTROL PANEL           ${NC}"
    echo -e "${CYAN}====================================================${NC}"
    echo -e "1) ${GREEN}Installer React Native CLI Community Stack${NC}"
    echo -e "2) ${GREEN}Configurer Wine Pro (DXVK, Fonts, .NET)${NC}"
    echo -e "3) ${GREEN}Installer Docker & Docker Compose${NC}"
    echo -e "4) ${GREEN}Optimiser les performances NVIDIA${NC}"
    echo -e "5) ${BLUE}Mettre à jour le système${NC}"
    echo -e "q) Quitter"
    echo -e "${CYAN}----------------------------------------------------${NC}"
}

install_react_native() {
    echo -e "${CYAN}[*] Installation de React Native Stack...${NC}"
    sudo apt update
    # Node.js et JDK sont déjà sur l'ISO, on configure le reste
    echo -e "${BLUE}Configuring Android SDK path...${NC}"
    mkdir -p $HOME/Android/Sdk
    echo 'export ANDROID_HOME=$HOME/Android/Sdk' >> ~/.zshrc
    echo 'export PATH=$PATH:$ANDROID_HOME/emulator' >> ~/.zshrc
    echo 'export PATH=$PATH:$ANDROID_HOME/platform-tools' >> ~/.zshrc
    
    echo -e "${BLUE}Installing Global NPM packages...${NC}"
    sudo npm install -g react-native-cli vercel netlify-cli
    
    echo -e "${GREEN}[+] React Native Stack configurée !${NC}"
    echo -e "Note: Vous devrez télécharger le SDK Android via Android Studio ou le CLI plus tard."
    read -p "Appuyez sur Entrée pour continuer..."
}

setup_wine() {
    echo -e "${CYAN}[*] Configuration de Wine Pro...${NC}"
    winetricks -q dxvk corefonts dotnet48
    echo -e "${GREEN}[+] Wine est prêt !${NC}"
    read -p "Appuyez sur Entrée pour continuer..."
}

while true; do
    show_menu
    read -p "Choisissez une option: " choice
    case $choice in
        1) install_react_native ;;
        2) setup_wine ;;
        3) sudo apt install -y docker.io docker-compose && sudo usermod -aG docker $USER ;;
        4) nvidia-settings ;;
        5) sudo apt update && sudo apt upgrade -y ;;
        q) exit 0 ;;
        *) echo -e "${RED}Option invalide.${NC}" ; sleep 1 ;;
    esac
done
